{
  "_comment": "发票字段提取规则——纯数据，不写死在代码里。换/修一种发票版式，只改这里即可。",
  "fields": {
    "invoice_no": {
      "patterns": [
        "发票号码\\s*[:：]?\\s*([0-9]{15,20})",
        "No\\.?\\s*[:：]?\\s*([0-9]{15,20})",
        "号码\\s*[:：]?\\s*([0-9]{20})",
        "\\b([0-9]{20})\\b"
      ]
    },
    "amount": {
      "patterns": [
        "价\\s*税\\s*合\\s*计[^¥￥]{0,40}[¥￥]?\\s*([\\d,]+\\.\\d{2})",
        "价税合计[（(]小写[）)]\\s*[:：]?\\s*[¥￥]?\\s*([\\d,]+\\.\\d{2})",
        "小写\\s*[¥￥]?\\s*([\\d,]+\\.\\d{2})"
      ],
      "coerce": "money",
      "fallback": "max_money"
    },
    "buyer": {
      "patterns": [
        "购买方[^名称]{0,12}名称[:：]\\s*([\\u4e00-\\u9fa5A-Za-z0-9·（）()]{2,30}?)\\s*(?:统一社会信用代码|纳税人识别号)",
        "名称[:：]\\s*([\\u4e00-\\u9fa5A-Za-z0-9·（）()]{2,30}?)\\s*(?:统一社会信用代码|纳税人识别号)"
      ]
    },
    "seller": {
      "patterns": [
        "销售方[^名称]{0,12}名称[:：]\\s*([\\u4e00-\\u9fa5A-Za-z0-9·（）()]{2,30}?)\\s*(?:统一社会信用代码|纳税人识别号)",
        "销货单位[^名称]{0,12}名称[:：]\\s*([\\u4e00-\\u9fa5A-Za-z0-9·（）()]{2,30}?)\\s*(?:统一社会信用代码|纳税人识别号)"
      ]
    },
    "invoice_date": {
      "patterns": [
        "开票日期[:：]?\\s*(\\d{4}\\s*年\\s*\\d{1,2}\\s*月\\s*\\d{1,2}\\s*日)",
        "开票日期[:：]?\\s*(\\d{4}-\\d{2}-\\d{2})"
      ]
    },
    "city": {
      "hint_in": "text",
      "cities": ["天津", "北京", "广州", "深圳", "上海", "杭州", "成都", "武汉", "西安", "南京", "重庆", "苏州", "佛山", "东莞"]
    }
  },
  "invoice_keywords": ["发票", "电子发票", "增值税", "普通发票", "专用发票", "invoice", "报销", "行程单"],
  "_comment_pdf_invoice_keywords": "附件/PDF 发票识别的「强证据」关键词：PDF 正文含其一才视为发票。普通 PDF（合同/报告/账单）即使恰好含一串 20 位数字，也不应被当作发票入库——这是把'只是因为它是 PDF'挡在门外的关键闸门。",
  "pdf_invoice_keywords": ["发票", "增值税", "普通发票", "专用发票", "电子发票", "全电发票", "价税合计", "销售方", "购买方", "开票日期", "纳税人识别号", "发票代码", "发票号码", "税额"],
  "_comment_detect_attachment_invoices": "附件发票探测：邮件标题没写发票关键词、但带了 PDF 附件时，也下载解析该附件（默认开）。误判严重时设为 false 可回退到只看标题的旧行为。",
  "detect_attachment_invoices": true
}
